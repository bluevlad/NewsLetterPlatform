# Gmail SMTP
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Database
DATABASE_URL=sqlite:///./data/newsletterplatform.db

# Scheduler (24h format)
# AllergyInsight
ALLERGY_COLLECT_HOUR=7
ALLERGY_COLLECT_MINUTE=30
ALLERGY_SEND_HOUR=8
ALLERGY_SEND_MINUTE=30

# Tenant API URLs
ALLERGY_INSIGHT_API_URL=http://localhost:9040

# 페르소나 적응형 뉴스레터 — AllergyInsight Newsletter API 인증 키
# AllergyInsight 측 NEWSLETTER_API_KEY 와 동일 값으로 설정. 빈 값이면 페르소나 기능 비활성화.
ALLERGY_INSIGHT_NEWSLETTER_KEY=

# Web Server
WEB_HOST=0.0.0.0
WEB_PORT=4055

# Security
# 관리자 세션 서명 시크릿(안정값). 설정 시 세션이 재시작·다중 워커에서 유지된다.
# 비우면 기동 시 임의 생성(재시작마다 관리자 재로그인). 운영 필수. 생성: openssl rand -hex 32
SESSION_SECRET=
# 리버스 프록시 신뢰 홉 수 — X-Forwarded-For 오른쪽에서 N번째를 클라이언트 IP로 신뢰.
# nginx 게이트웨이 1단이면 1, 앞단에 CDN이 있으면 2.
TRUSTED_PROXY_HOPS=1
# CSRF 허용 호스트 추가(쉼표 구분). web_base_url 호스트는 자동 허용.
CSRF_ALLOWED_HOSTS=

# Logging
LOG_LEVEL=INFO

# TechBriefing — Ollama LLM deep analyzer (Top N 카드 4섹션 분석)
# 로컬 dev/CLI:  http://localhost:11434
# Docker 컨테이너: http://host.docker.internal:11434  (docker-compose extra_hosts 필요)
OLLAMA_BASE_URL=http://localhost:11434
TECH_BRIEFING_LLM_ENABLED=true
TECH_BRIEFING_LLM_MODEL=qwen2.5-coder:14b
TECH_BRIEFING_LLM_TIMEOUT_SEC=90
TECH_BRIEFING_LLM_TOP_N=5
TECH_BRIEFING_LLM_TEMPERATURE=0.2
