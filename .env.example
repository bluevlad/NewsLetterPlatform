# Gmail SMTP
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Database
DATABASE_URL=sqlite:///./data/newsletterplatform.db

# Scheduler (24h format)
# AllergyInsight
ALLERGY_COLLECT_HOUR=7
ALLERGY_COLLECT_MINUTE=30
ALLERGY_SEND_HOUR=8
ALLERGY_SEND_MINUTE=30

# Tenant API URLs
ALLERGY_INSIGHT_API_URL=http://localhost:9040

# Web Server
WEB_HOST=0.0.0.0
WEB_PORT=4055

# Logging
LOG_LEVEL=INFO

# TechBriefing — Ollama LLM deep analyzer (Top N 카드 4섹션 분석)
# 로컬 dev/CLI:  http://localhost:11434
# Docker 컨테이너: http://host.docker.internal:11434  (docker-compose extra_hosts 필요)
OLLAMA_BASE_URL=http://localhost:11434
TECH_BRIEFING_LLM_ENABLED=true
TECH_BRIEFING_LLM_MODEL=qwen2.5-coder:14b
TECH_BRIEFING_LLM_TIMEOUT_SEC=90
TECH_BRIEFING_LLM_TOP_N=5
TECH_BRIEFING_LLM_TEMPERATURE=0.2
